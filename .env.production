# ============================================
# 🌐 网络配置
# ============================================
# 代理前缀
VITE_APP_BASE_API = '/prod-api'
# 项目名称
VITE_APP_TITLE=低空智能巡检平台
# WebSocket 端点
VITE_APP_WS_ENDPOINT=wss://api.dikong.com/ws

# ============================================
# 🎛️ 功能开关
# ============================================
# 多租户（需与后端 app.tenant.enabled 保持一致）
VITE_APP_TENANT_ENABLED=true

# 风场可视化起始点（经纬高，未配置时回退到内置默认值）
# VITE_RADAR_START_LATITUDE=22.252818819444443
# VITE_RADAR_START_LONGITUDE=113.52958706944445
# VITE_RADAR_START_ALTITUDE_METERS=86.885

# 可选：普通 Cesium terrain 服务地址，优先级高于 Ion terrain asset id
# VITE_CESIUM_TERRAIN_URL=https://data.mars3d.cn/terrain
# 可选：自定义 Cesium Ion 地形资源 ID；未配置时回退到默认 world terrain
# VITE_CESIUM_ION_TERRAIN_ASSET_ID=
