# 应用端口
VITE_APP_PORT=8005
# 项目名称
VITE_APP_TITLE=低空智能巡检平台
# 代理前缀
VITE_APP_BASE_API=/dev-api

# 接口地址
# VITE_APP_API_URL=https://api.youlai.tech         # 线上
# VITE_APP_API_URL=https://api.youlai.tech/v2    # 线上(多租户)
VITE_APP_API_URL=http://localhost:8000             # 本地

# WebSocket 端点（飞行控制台实时数据推送）
# VITE_APP_WS_ENDPOINT=ws://localhost:8000/ws
VITE_APP_WS_ENDPOINT=

# 启用 Mock 服务(true:开启 false:关闭)
VITE_MOCK_DEV_SERVER=true

# 多租户开关(true:开启 false:关闭)
VITE_APP_TENANT_ENABLED=true

# 风场可视化起始点（经纬高，未配置时回退到内置默认值）
VITE_RADAR_START_LATITUDE=22.252818819444443
VITE_RADAR_START_LONGITUDE=113.52978706944445
VITE_RADAR_START_ALTITUDE_METERS=46.885
